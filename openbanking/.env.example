# FOID — Open Banking Polling Service
# Environment variables
# ---------------------
# Copy this file to .env and fill in values marked <CHANGE_ME>.
# Never commit the real .env file to git.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development / testing):
DATABASE_URL=sqlite+aiosqlite:///./foid_openbanking.db

# Postgres (production) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/foid_openbanking

# Set to "true" to log every SQL statement (useful for debugging queries)
DB_ECHO=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be changed to a strong random secret before going to production.
JWT_SECRET=<CHANGE_ME>

# ── Open Banking Poller ───────────────────────────────────────────────────────
# How often the poller checks each user's feed (seconds).
# Use 10 during development, 300 (5 min) in production.
POLL_INTERVAL_SECONDS=10

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
RELOAD=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
